{
	"manifest_version": 3,
	"name": "Proxy Receiver",
	"version": "1.0.0",
	"permissions": [
		"proxy",
		"storage",
		"declarativeNetRequest",
		"declarativeNetRequestWithHostAccess"
	],
	"host_permissions": ["<all_urls>"],
	"background": {
		"service_worker": "service_worker.js"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "Proxy Receiver"
	}
}
