  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "email": {
                  "example": "john@example.com",
                  "type": "string"
                },
                "password": {
                  "example": "secret123",
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешный вход",
            "schema": {
              "properties": {
                "access_token": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "refresh_token": {
                  "type": "string"
                },
                "user": {
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "401": {
            "description": "Неверный email или пароль"
          }
        },
        "summary": "Аутентификация пользователя",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "access_token": {
                  "required": true,
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Текущий пользователь",
            "schema": {
              "properties": {
                "is_authenticated": {
                  "type": "boolean"
                },
                "message": {
                  "type": "string"
                },
                "user": {
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "400": {
            "description": "Токен не передан"
          },
          "401": {
            "description": "Неверный токен"
          }
        },
        "summary": "Получить текущего пользователя",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/register": {
