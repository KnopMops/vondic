# Vondic Desktop Client - Environment Variables
# Copy this file to .env.desktop and fill in the values

# Backend API URL
VONDIC_BACKEND_URL=http://localhost:5000

# Yandex OAuth Settings (must match backend .env.backend)
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_REDIRECT_URI=http://localhost:5000/api/v1/auth/yandex/callback

# App Settings
APP_NAME=Vondic
APP_VERSION=1.0.0
