FLASK_APP=run.py
FLASK_DEBUG=

SECRET_KEY=
DATABASE_URL=

POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=

REDIS_URL=
CACHE_DEFAULT_TIMEOUT=300
RABBITMQ_URL=

MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USE_SSL=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_DOMAIN=vondic.ru
MAIL_TLS_SERVER_NAME=mail.vondic.ru

# Свой docker-mailserver (после запуска docker-compose.mail.yml)
MAIL_IMAP_HOST=mail.vondic.ru
MAIL_IMAP_PORT=993
MAIL_IMAP_USE_TLS=True
MAIL_SMTP_INTERNAL_HOST=mail.vondic.ru
MAIL_SMTP_INTERNAL_PORT=587
# Отдельный ключ шифрования паролей ящиков в БД (Fernet base64).
# Если пусто — ключ хранится в UPLOADS_DIR/.mail_credentials_key (переживает пересборку).
# Для старых ящиков также пробуется SECRET_KEY.
MAIL_CREDENTIALS_KEY=
# 1 = backend создаёт ящики через docker exec (docker.sock + DOCKER_GID в compose)
MAIL_PROVISION_ENABLED=1
MAIL_DOCKER_CONTAINER=mailserver
MAIL_DOCKER_BIN=/usr/bin/docker
MAIL_DOCKER_SOCKET=/var/run/docker.sock
# noreply: API POST /api/public/v1/mail/noreply/send (поле password)
MAIL_NOREPLY_ADDRESS=noreply@vondic.ru
MAIL_NOREPLY_SMTP_PASSWORD=
MAIL_NOREPLY_API_PASSWORD=
# DOCKER_GID на хосте: export DOCKER_GID=$(getent group docker | cut -d: -f3)

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=
YANDEX_SMARTCAPTCHA_SERVER_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

OLLAMA_API_URL=
OLLAMA_MODEL=

STATIC_NGINX_URL=http://static-nginx:80
UPLOADS_DIR=/app/uploads
